---
export const prerender = false;
import { db } from "@/lib/db";
import { sites } from "@/db/schema";
import { eq } from "drizzle-orm";
import { THEMES } from "@/lib/themes";

const { slug } = Astro.params;
const database = db(Astro.locals.runtime.env.DB);
const [site] = await database.select().from(sites).where(eq(sites.slug, slug!));

if (!site) return Astro.redirect("/");

const STATUS_CONFIG = {
  live:      { bg: "rgba(22,163,74,0.09)",   text: "#16a34a", dot: "#22c55e",  label: "Live" },
  deploying: { bg: "rgba(202,138,4,0.09)",   text: "#b45309", dot: "#f59e0b",  label: "Building" },
  error:     { bg: "rgba(220,38,38,0.08)",   text: "#dc2626", dot: "#ef4444",  label: "Error" },
  pending:   { bg: "rgba(148,163,184,0.09)", text: "#64748b", dot: "#94a3b8",  label: "Pending" },
};

const sc = STATUS_CONFIG[site.status as keyof typeof STATUS_CONFIG] ?? STATUS_CONFIG.pending;
const theme = THEMES.find((t) => t.id === site.theme);
const p = theme?.preview ?? { bg: "#f1f5f9", text: "#0f172a", accent: "#64748b", secondary: "#94a3b8" };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name} — Food Generator</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root { --sans: 'Plus Jakarta Sans', system-ui, sans-serif; --ease: cubic-bezier(0.32,0.72,0,1); }
      body { font-family: var(--sans); background: #f8f7f4; min-height: 100dvh; color: #0f172a; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }

      .info-card {
        background: white; border: 1px solid rgba(0,0,0,0.055); border-radius: 14px; padding: 1.25rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.03), 0 3px 8px rgba(0,0,0,0.03);
      }
      .info-label {
        font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
        color: #94a3b8; margin-bottom: 10px; display: block;
      }

      .btn-primary {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 18px; background: #0f172a; color: white;
        font-family: var(--sans); font-size: 13px; font-weight: 700;
        border-radius: 100px; transition: all 0.3s var(--ease);
        letter-spacing: -0.01em; box-shadow: 0 2px 8px rgba(15,23,42,0.18);
      }
      .btn-primary:hover { background: #1e293b; transform: translateY(-1px); box-shadow: 0 5px 18px rgba(15,23,42,0.22); }

      .btn-ghost {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 15px; background: white; color: #475569;
        font-family: var(--sans); font-size: 13px; font-weight: 600;
        border-radius: 100px; border: 1.5px solid rgba(0,0,0,0.1);
        transition: all 0.25s var(--ease); letter-spacing: -0.01em;
      }
      .btn-ghost:hover { border-color: rgba(0,0,0,0.2); color: #0f172a; transform: translateY(-1px); }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .content-grid { animation: fadeUp 0.55s cubic-bezier(0.32,0.72,0,1) 0.1s both; }
    </style>
  </head>
  <body>

    <!-- Header -->
    <header style="background:#0f172a; padding:0 2rem; border-bottom:1px solid rgba(255,255,255,0.05);">
      <div style="max-width:1100px; margin:0 auto; padding:1rem 0; display:flex; align-items:center; justify-content:space-between;">
        <div style="display:flex; align-items:center; gap:11px;">
          <div style="width:32px; height:32px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2h18l-2 7H5L3 2z"/><path d="M5 9c0 7 14 7 14 0"/><path d="M12 16v6"/><path d="M8 22h8"/>
            </svg>
          </div>
          <span style="font-size:14px; font-weight:700; color:white; letter-spacing:-0.025em;">Food Generator</span>
        </div>
        <a href="/" style="font-size:12.5px; color:rgba(255,255,255,0.4); display:inline-flex; align-items:center; gap:4px; font-weight:500; transition:color 0.2s;"
           onmouseover="this.style.color='rgba(255,255,255,0.75)'"
           onmouseout="this.style.color='rgba(255,255,255,0.4)'">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Dashboard
        </a>
      </div>
    </header>

    <!-- Site hero banner — shows the theme palette -->
    <div style="background:white; border-bottom:1px solid rgba(0,0,0,0.05);">
      <div style={`position:relative; overflow:hidden;`}>
        <!-- Theme palette bar -->
        <div style={`height:5px; background:${p.accent};`} />
      </div>

      <div style="max-width:1100px; margin:0 auto; padding:1.75rem 2rem;">
        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1.25rem; flex-wrap:wrap;">

          <!-- Left: site identity -->
          <div>
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:5px; flex-wrap:wrap;">
              <h1 style="font-size:1.75rem; font-weight:800; color:#0f172a; letter-spacing:-0.04em; line-height:1;">{site.name}</h1>
              <span style={`display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:600; padding:3px 10px; border-radius:100px; background:${sc.bg}; color:${sc.text};`}>
                <span style={`width:5px; height:5px; border-radius:50%; background:${sc.dot}; flex-shrink:0;`} />
                {sc.label}
              </span>
            </div>
            <p style="font-size:12.5px; color:#94a3b8; font-family:ui-monospace,monospace; letter-spacing:-0.01em;">{site.slug}.pages.dev</p>
            {theme && (
              <div style="display:flex; align-items:center; gap:6px; margin-top:8px;">
                <div style={`width:10px; height:10px; border-radius:3px; background:${p.accent}; flex-shrink:0;`} />
                <div style={`width:10px; height:10px; border-radius:3px; background:${p.bg}; border:1px solid rgba(0,0,0,0.1); flex-shrink:0;`} />
                <div style={`width:10px; height:10px; border-radius:3px; background:${p.secondary}; flex-shrink:0;`} />
                <span style="font-size:12px; color:#64748b; font-weight:500; margin-left:2px;">{theme.name}</span>
              </div>
            )}
          </div>

          <!-- Right: actions -->
          <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
            {site.formData && (
              <a href={`/sites/${site.slug}/edit`} class="btn-primary">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit site
              </a>
            )}
            {site.deployUrl && (
              <a href={site.deployUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                View live
              </a>
            )}
            <a href={site.githubRepo} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.74-1.33-1.74-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.25 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
            <a href={`https://dash.cloudflare.com/pages/view/${site.cfProjectName}`} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              CF Pages
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Detail content -->
    <main class="content-grid" style="max-width:1100px; margin:0 auto; padding:2rem; display:grid; grid-template-columns:1fr 1fr; gap:1rem; align-items:start;">

      <div class="info-card">
        <span class="info-label">Theme</span>
        <div style="display:flex; align-items:center; gap:8px;">
          <div style="display:flex; gap:3px;">
            <div style={`width:12px; height:12px; border-radius:3px; background:${p.bg}; border:1px solid rgba(0,0,0,0.1);`} />
            <div style={`width:12px; height:12px; border-radius:3px; background:${p.accent};`} />
            <div style={`width:12px; height:12px; border-radius:3px; background:${p.secondary};`} />
          </div>
          <p style="font-size:14.5px; font-weight:700; color:#0f172a; letter-spacing:-0.02em;">{theme?.name ?? site.theme}</p>
        </div>
        {theme && (
          <p style="font-size:12px; color:#94a3b8; margin-top:6px;">{theme.description}</p>
        )}
      </div>

      <div class="info-card">
        <span class="info-label">Deploy URL</span>
        {site.deployUrl
          ? <a href={site.deployUrl} target="_blank" rel="noopener noreferrer" style="font-size:13.5px; font-weight:500; color:#0f172a; word-break:break-all; display:block; text-decoration:underline; text-underline-offset:2px; text-decoration-color:rgba(0,0,0,0.2);">{site.deployUrl}</a>
          : <p style="font-size:13.5px; color:#94a3b8; font-style:italic;">Pending first deploy</p>
        }
      </div>

      <div class="info-card">
        <span class="info-label">CF Project</span>
        <p style="font-size:13.5px; font-weight:600; color:#0f172a; font-family:ui-monospace,monospace; letter-spacing:-0.01em;">{site.cfProjectName}</p>
      </div>

      <div class="info-card">
        <span class="info-label">Created</span>
        <p style="font-size:15px; font-weight:700; color:#0f172a; letter-spacing:-0.02em;">
          {site.createdAt ? new Date(site.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }) : "—"}
        </p>
      </div>

      <!-- Full-width CTA / notice -->
      <div style="grid-column:1/-1;">
        {site.formData
          ? (
            <div style="padding:1.5rem 1.75rem; background:white; border:1px solid rgba(0,0,0,0.055); border-radius:16px; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; box-shadow:0 1px 2px rgba(0,0,0,0.03);">
              <div>
                <p style="font-size:14px; font-weight:700; color:#0f172a; margin-bottom:4px; letter-spacing:-0.02em;">Ready to edit</p>
                <p style="font-size:13px; color:#64748b; line-height:1.6;">Update content, photos, translations or settings. Changes push to GitHub and deploy automatically.</p>
              </div>
              <a href={`/sites/${site.slug}/edit`} class="btn-primary" style="white-space:nowrap; flex-shrink:0;">
                Edit site
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          )
          : (
            <div style="padding:1.5rem 1.75rem; background:#fffbeb; border:1px solid #fde68a; border-radius:16px;">
              <p style="font-size:13.5px; font-weight:700; color:#92400e; margin-bottom:6px;">No saved form data</p>
              <p style="font-size:13px; color:#b45309; line-height:1.65;">
                This site was created before the edit feature was added. Edit
                <code style="background:#fef3c7; padding:1px 6px; border-radius:5px; font-size:12px; margin:0 3px;">src/config/site.ts</code> and
                <code style="background:#fef3c7; padding:1px 6px; border-radius:5px; font-size:12px; margin:0 3px;">src/i18n/en.json</code>
                directly in the <a href={`${site.githubRepo}/edit/master/src/config/site.ts`} target="_blank" rel="noopener noreferrer" style="color:#b45309; text-decoration:underline;">GitHub repo</a>.
              </p>
            </div>
          )
        }
      </div>
    </main>

  </body>
</html>
