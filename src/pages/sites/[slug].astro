---
export const prerender = false;
import { db } from "@/lib/db";
import { sites } from "@/db/schema";
import { eq } from "drizzle-orm";

const { slug } = Astro.params;
const database = db(Astro.locals.runtime.env.DB);
const [site] = await database.select().from(sites).where(eq(sites.slug, slug!));

if (!site) return Astro.redirect("/");

const statusColors: Record<string, { bg: string; text: string }> = {
  live: { bg: "#dcfce7", text: "#166534" },
  deploying: { bg: "#fef9c3", text: "#854d0e" },
  error: { bg: "#fee2e2", text: "#991b1b" },
  pending: { bg: "#f3f4f6", text: "#374151" },
};
const colors = statusColors[site.status] ?? statusColors["pending"];

const ghRepoName = site.githubRepo.split("/").pop();
const ghOwner = site.githubRepo.split("/").slice(-2)[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name} — Food Generator</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Inter, system-ui, sans-serif; background: #f8fafc; min-height: 100dvh; color: #111827; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <div style="max-width:860px; margin:0 auto; padding:3rem 1.5rem 6rem;">

      <!-- Breadcrumb -->
      <a href="/" style="display:inline-flex; align-items:center; gap:6px; font-size:13px; color:#6b7280; margin-bottom:2rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Dashboard
      </a>

      <!-- Header -->
      <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:2.5rem;">
        <div>
          <h1 style="font-size:1.75rem; font-weight:600; color:#111827;">{site.name}</h1>
          <p style="font-size:14px; color:#9ca3af; margin-top:4px;">{site.slug}</p>
        </div>
        <span style={`font-size:12px; font-weight:500; padding:4px 12px; border-radius:9999px; background:${colors.bg}; color:${colors.text};`}>
          {site.status}
        </span>
      </div>

      <!-- Quick links -->
      <div style="display:flex; gap:10px; margin-bottom:2.5rem; flex-wrap:wrap;">
        {site.deployUrl && (
          <a href={site.deployUrl} target="_blank" rel="noopener noreferrer"
             style="display:inline-flex; align-items:center; gap:6px; padding:9px 16px; background:#111827; color:#fff; font-size:13px; font-weight:500; border-radius:8px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            View live site
          </a>
        )}
        <a href={site.githubRepo} target="_blank" rel="noopener noreferrer"
           style="display:inline-flex; align-items:center; gap:6px; padding:9px 16px; background:#fff; border:1px solid #e5e7eb; color:#374151; font-size:13px; font-weight:500; border-radius:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.74-1.33-1.74-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.25 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub repo
        </a>
        <a href={`https://dash.cloudflare.com/${site.cfProjectName}`} target="_blank" rel="noopener noreferrer"
           style="display:inline-flex; align-items:center; gap:6px; padding:9px 16px; background:#fff; border:1px solid #e5e7eb; color:#374151; font-size:13px; font-weight:500; border-radius:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          CF Pages
        </a>
      </div>

      <!-- Info grid -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:1.25rem;">
          <p style="font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:#9ca3af; margin-bottom:8px;">Theme</p>
          <p style="font-size:15px; font-weight:500; color:#111827;">{site.theme}</p>
        </div>
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:1.25rem;">
          <p style="font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:#9ca3af; margin-bottom:8px;">CF Project</p>
          <p style="font-size:15px; font-weight:500; color:#111827;">{site.cfProjectName}</p>
        </div>
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:1.25rem;">
          <p style="font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:#9ca3af; margin-bottom:8px;">Created</p>
          <p style="font-size:15px; font-weight:500; color:#111827;">
            {site.createdAt ? new Date(site.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }) : "—"}
          </p>
        </div>
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:1.25rem;">
          <p style="font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:#9ca3af; margin-bottom:8px;">Deploy URL</p>
          {site.deployUrl
            ? <a href={site.deployUrl} target="_blank" rel="noopener noreferrer" style="font-size:14px; font-weight:500; color:#2563eb; word-break:break-all;">{site.deployUrl}</a>
            : <p style="font-size:14px; color:#9ca3af;">Pending first deploy</p>
          }
        </div>
      </div>

      <!-- Edit note -->
      <div style="margin-top:2rem; padding:1.25rem 1.5rem; background:#fffbeb; border:1px solid #fde68a; border-radius:10px;">
        <p style="font-size:13px; font-weight:500; color:#92400e; margin-bottom:4px;">To edit this site</p>
        <p style="font-size:13px; color:#b45309;">
          Edit <code style="background:#fef3c7; padding:1px 5px; border-radius:4px; font-size:12px;">src/config/site.ts</code> and <code style="background:#fef3c7; padding:1px 5px; border-radius:4px; font-size:12px;">src/i18n/en.json</code> directly in the
          <a href={`${site.githubRepo}/edit/master/src/config/site.ts`} target="_blank" rel="noopener noreferrer" style="color:#b45309; text-decoration:underline;">GitHub repo</a>.
          Every push to master redeploys automatically.
        </p>
      </div>

    </div>
  </body>
</html>
