---
export const prerender = false;
import { db } from "@/lib/db";
import { sites } from "@/db/schema";
import { THEMES } from "@/lib/themes";

const database = db(Astro.locals.runtime.env.DB);
const allSites = await database.select().from(sites).orderBy(sites.createdAt);

const liveCount = allSites.filter((s) => s.status === "live").length;
const deployingCount = allSites.filter((s) => s.status === "deploying").length;

const STATUS_CONFIG = {
  live:      { bg: "rgba(22,163,74,0.09)",   text: "#16a34a", dot: "#22c55e",  label: "Live" },
  deploying: { bg: "rgba(202,138,4,0.09)",   text: "#b45309", dot: "#f59e0b",  label: "Building" },
  error:     { bg: "rgba(220,38,38,0.08)",   text: "#dc2626", dot: "#ef4444",  label: "Error" },
  pending:   { bg: "rgba(148,163,184,0.09)", text: "#64748b", dot: "#94a3b8",  label: "Pending" },
};

const themeMap = Object.fromEntries(THEMES.map((t) => [t.id, t]));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Food Generator — Arkadya</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root { --sans: 'Plus Jakarta Sans', system-ui, sans-serif; --ease: cubic-bezier(0.32,0.72,0,1); }
      body { font-family: var(--sans); background: #f8f7f4; min-height: 100dvh; color: #0f172a; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }

      .site-card {
        display: block; background: white; border-radius: 18px; overflow: hidden;
        border: 1px solid rgba(0,0,0,0.055);
        box-shadow: 0 1px 2px rgba(0,0,0,0.03), 0 3px 10px rgba(0,0,0,0.04);
        transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease), border-color 0.3s;
        color: inherit; text-decoration: none;
      }
      .site-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 40px rgba(0,0,0,0.09), 0 2px 8px rgba(0,0,0,0.04);
        border-color: rgba(0,0,0,0.09);
      }

      .btn-new {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 16px 8px 12px;
        background: white; color: #0f172a;
        font-family: var(--sans); font-size: 13px; font-weight: 700;
        border-radius: 100px; border: none;
        transition: all 0.35s var(--ease);
        letter-spacing: -0.01em; text-decoration: none;
      }
      .btn-new:hover { background: #e8e7e4; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,0,0,0.15); }
      .btn-new .plus-wrap {
        width: 22px; height: 22px; background: #0f172a;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        transition: transform 0.4s var(--ease);
      }
      .btn-new:hover .plus-wrap { transform: rotate(90deg); }

      .chip {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 11.5px; font-weight: 600; padding: 4px 10px;
        border-radius: 100px; background: #f8f7f4; color: #475569;
        border: 1px solid rgba(0,0,0,0.07);
        transition: all 0.2s var(--ease); text-decoration: none;
      }
      .chip:hover { background: #f0efec; border-color: rgba(0,0,0,0.12); }
      .chip-primary { background: rgba(15,23,42,0.05); color: #0f172a; border-color: rgba(15,23,42,0.1); }
      .chip-primary:hover { background: rgba(15,23,42,0.09); }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .empty-state { animation: fadeUp 0.65s var(--ease) both; }
      .site-card:nth-child(1) { animation: fadeUp 0.5s 0.04s var(--ease) both; }
      .site-card:nth-child(2) { animation: fadeUp 0.5s 0.09s var(--ease) both; }
      .site-card:nth-child(3) { animation: fadeUp 0.5s 0.13s var(--ease) both; }
      .site-card:nth-child(4) { animation: fadeUp 0.5s 0.17s var(--ease) both; }
      .site-card:nth-child(5) { animation: fadeUp 0.5s 0.21s var(--ease) both; }
      .site-card:nth-child(6) { animation: fadeUp 0.5s 0.25s var(--ease) both; }
    </style>
  </head>
  <body>

    <!-- Header -->
    <header style="background:#0f172a; padding:0 2rem; position:sticky; top:0; z-index:10; border-bottom:1px solid rgba(255,255,255,0.05);">
      <div style="max-width:1200px; margin:0 auto; padding:1rem 0; display:flex; align-items:center; justify-content:space-between;">

        <!-- Wordmark -->
        <div style="display:flex; align-items:center; gap:11px;">
          <div style="width:32px; height:32px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2h18l-2 7H5L3 2z"/><path d="M5 9c0 7 14 7 14 0"/><path d="M12 16v6"/><path d="M8 22h8"/>
            </svg>
          </div>
          <div>
            <span style="display:block; font-size:10px; font-weight:600; color:rgba(255,255,255,0.28); text-transform:uppercase; letter-spacing:0.13em; line-height:1; margin-bottom:2px;">Arkadya</span>
            <span style="font-size:14px; font-weight:700; color:white; letter-spacing:-0.025em; line-height:1;">Food Generator</span>
          </div>
        </div>

        <!-- Stats + CTA -->
        <div style="display:flex; align-items:center; gap:1.375rem;">
          {allSites.length > 0 && (
            <div style="display:flex; align-items:center; gap:16px;">
              <div style="text-align:right;">
                <p style="font-size:9.5px; font-weight:600; color:rgba(255,255,255,0.28); text-transform:uppercase; letter-spacing:0.11em; margin-bottom:2px;">total</p>
                <p style="font-size:17px; font-weight:800; color:white; line-height:1; letter-spacing:-0.03em;">{allSites.length}</p>
              </div>
              <div style="width:1px; height:24px; background:rgba(255,255,255,0.08);" />
              <div style="text-align:right;">
                <p style="font-size:9.5px; font-weight:600; color:rgba(255,255,255,0.28); text-transform:uppercase; letter-spacing:0.11em; margin-bottom:2px;">live</p>
                <p style="font-size:17px; font-weight:800; color:#4ade80; line-height:1; letter-spacing:-0.03em;">{liveCount}</p>
              </div>
              {deployingCount > 0 && (
                <>
                  <div style="width:1px; height:24px; background:rgba(255,255,255,0.08);" />
                  <div style="text-align:right;">
                    <p style="font-size:9.5px; font-weight:600; color:rgba(255,255,255,0.28); text-transform:uppercase; letter-spacing:0.11em; margin-bottom:2px;">building</p>
                    <p style="font-size:17px; font-weight:800; color:#fbbf24; line-height:1; letter-spacing:-0.03em;">{deployingCount}</p>
                  </div>
                </>
              )}
              <div style="width:1px; height:24px; background:rgba(255,255,255,0.08);" />
            </div>
          )}
          <a href="/new" class="btn-new">
            <span class="plus-wrap">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
            New site
          </a>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main style="max-width:1200px; margin:0 auto; padding:2.5rem 2rem 6rem;">

      {allSites.length === 0 ? (

        <!-- Empty state -->
        <div class="empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:60vh; text-align:center; padding:4rem 2rem;">
          <div style="width:72px; height:72px; background:#0f172a; border-radius:20px; display:flex; align-items:center; justify-content:center; margin-bottom:2rem; box-shadow:0 8px 32px rgba(0,0,0,0.18);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.88)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2h18l-2 7H5L3 2z"/><path d="M5 9c0 7 14 7 14 0"/><path d="M12 16v6"/><path d="M8 22h8"/>
            </svg>
          </div>
          <p style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.13em; color:#94a3b8; margin-bottom:14px;">Ready when you are</p>
          <h2 style="font-size:2.375rem; font-weight:800; color:#0f172a; letter-spacing:-0.05em; margin-bottom:14px; line-height:1.1;">Your first restaurant<br/>site, in minutes.</h2>
          <p style="font-size:15px; color:#64748b; margin-bottom:2.75rem; max-width:360px; line-height:1.7; font-weight:400;">
            Booking forms, menus, maps, and multilingual support — deployed to Cloudflare Pages automatically.
          </p>
          <a href="/new" class="btn-new" style="background:#0f172a; color:white; font-size:14px; padding:11px 22px 11px 14px;">
            <span style="width:24px; height:24px; background:rgba(255,255,255,0.12); border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
            Create first site
          </a>
        </div>

      ) : (

        <div>
          <!-- Page title -->
          <div style="margin-bottom:1.75rem; display:flex; align-items:baseline; gap:10px;">
            <h2 style="font-size:1.375rem; font-weight:800; color:#0f172a; letter-spacing:-0.04em;">
              {allSites.length} {allSites.length === 1 ? "site" : "sites"}
            </h2>
            <span style="font-size:13px; color:#94a3b8; font-weight:400;">
              {liveCount} live{deployingCount > 0 ? ` · ${deployingCount} building` : ""}
            </span>
          </div>

          <!-- Cards grid -->
          <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:1.125rem;">
            {allSites.map((site) => {
              const sc = STATUS_CONFIG[site.status as keyof typeof STATUS_CONFIG] ?? STATUS_CONFIG.pending;
              const theme = themeMap[site.theme];
              const p = theme?.preview ?? { bg: "#f1f5f9", text: "#0f172a", accent: "#64748b", secondary: "#94a3b8" };
              return (
                <a href={`/sites/${site.slug}`} class="site-card">

                  {/* Theme palette preview */}
                  <div style={`position:relative; height:96px; background:${p.bg}; overflow:hidden; display:flex; align-items:center; padding:0 1.375rem;`}>
                    {/* Accent strips on right edge */}
                    <div style={`position:absolute; right:0; top:0; bottom:0; width:8px; background:${p.secondary}; opacity:0.55;`} />
                    <div style={`position:absolute; right:8px; top:0; bottom:0; width:26px; background:${p.accent};`} />

                    {/* Site name + theme label */}
                    <div style="flex:1; min-width:0; padding-right:3rem;">
                      <p style={`font-size:9.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:${p.accent}; margin-bottom:6px; opacity:0.88;`}>
                        {theme?.name ?? site.theme}
                      </p>
                      <p style={`font-size:1.1rem; font-weight:700; color:${p.text}; letter-spacing:-0.025em; line-height:1.2; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;`}>
                        {site.name}
                      </p>
                    </div>
                  </div>

                  {/* Card body */}
                  <div style="padding:1rem 1.25rem;">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.875rem;">
                      <code style="font-size:11.5px; color:#94a3b8; letter-spacing:-0.01em; font-family:ui-monospace,monospace;">
                        {site.slug}.pages.dev
                      </code>
                      <span style={`display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:600; padding:3px 9px; border-radius:100px; background:${sc.bg}; color:${sc.text};`}>
                        <span style={`width:5px; height:5px; border-radius:50%; background:${sc.dot}; flex-shrink:0;`} />
                        {sc.label}
                      </span>
                    </div>

                    {/* Action chips */}
                    <div style="display:flex; align-items:center; gap:6px; padding-top:0.75rem; border-top:1px solid rgba(0,0,0,0.045);">
                      {site.deployUrl && (
                        <a href={site.deployUrl} target="_blank" rel="noopener noreferrer"
                           onclick="event.stopPropagation()"
                           class="chip chip-primary">
                          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                          </svg>
                          View
                        </a>
                      )}
                      {site.formData && (
                        <a href={`/sites/${site.slug}/edit`}
                           onclick="event.stopPropagation()"
                           class="chip">
                          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                          </svg>
                          Edit
                        </a>
                      )}
                      {site.createdAt && (
                        <span style="font-size:11px; color:#cbd5e1; margin-left:auto; font-weight:400;">
                          {new Date(site.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "short" })}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>

      )}
    </main>
  </body>
</html>
